{
  "name": "typescript-discord-bot",
  "version": "1.0.0",
  "description": "A powerful TypeScript Discord moderation bot",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev:bot": "nodemon --exec ts-node src/bot.ts",
    "dev:manager": "nodemon --exec ts-node src/manager.ts",
    "prestart:bot": "npm run build",
    "prestart:manager": "npm run build",
    "start": "npm run start:bot",
    "start:bot": "node ./dist/bot.js",
    "start:manager": "node ./dist/manager.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppauel/typescript-discord-bot.git"
  },
  "author": "pauel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ppauel/typescript-discord-bot/issues"
  },
  "homepage": "https://github.com/ppauel/typescript-discord-bot#readme",
  "dependencies": {
    "@fluent/bundle": "^0.18.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "mongoose": "^8.0.0",
    "ms": "^2.1.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/ms": "^0.7.34",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.7.0",
    "typescript": "^5.6.3"
  }
}
